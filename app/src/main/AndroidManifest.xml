<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">
    <uses-permission android:name="moe.shizuku.manager.permission.API_V23" />
    <uses-permission android:name="android.permission.QUERY_ALL_PACKAGES" />
    <uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW" />
    <uses-permission android:name="android.permission.BIND_ACCESSIBILITY_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MEDIA_PROJECTION" />

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:windowSoftInputMode="adjustResize"
        android:theme="@style/Theme.CoverScreenMirror">
        <meta-data android:name="com.samsung.android.multidisplay.keep_process_alive" android:value="true"/>
        <meta-data android:name="com.samsung.android.multidisplay.activity.show_on_cover" android:value="true"/>
        <meta-data android:name="com.samsung.android.knox.allow_on_cover_screen" android:value="true"/>
        <meta-data android:name="moe.shizuku.client.V3_SUPPORT" android:value="true"/>
        
        <activity
            android:name=".MainActivity"
            android:configChanges="orientation|screenSize|smallestScreenSize|screenLayout|density|keyboardHidden|keyboard"
            android:exported="true">
            <meta-data android:name="com.samsung.android.multidisplay.keep_process_alive" android:value="true"/>
            <meta-data android:name="com.samsung.android.multidisplay.activity.show_on_cover" android:value="true"/>
            <meta-data android:name="com.samsung.android.knox.allow_on_cover_screen" android:value="true"/>
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
        
        <activity android:name=".CoverScreenActivity" 
            android:configChanges="orientation|screenSize|smallestScreenSize|screenLayout|density|keyboardHidden|keyboard"
            android:exported="true" 
            android:excludeFromRecents="true" 
            android:theme="@style/Theme.CoverScreenMirror">
            <meta-data android:name="com.samsung.android.multidisplay.keep_process_alive" android:value="true"/>
            <meta-data android:name="com.samsung.android.multidisplay.activity.show_on_cover" android:value="true"/>
            <meta-data android:name="com.samsung.android.knox.allow_on_cover_screen" android:value="true"/>
        </activity>

        <service android:name=".ScreenMirrorService" android:foregroundServiceType="mediaProjection" android:exported="false" />

        <service
            android:name=".CoverScreenAccessibilityService"
            android:permission="android.permission.BIND_ACCESSIBILITY_SERVICE"
            android:exported="true">
            <intent-filter>
                <action android:name="android.accessibilityservice.AccessibilityService" />
            </intent-filter>
            <meta-data
                android:name="android.accessibilityservice"
                android:resource="@xml/accessibility_service_config" />
        </service>

        
        <provider 
            android:authorities="com.example.coverscreenmirror.shizuku" 
            android:enabled="true" 
            android:exported="true" 
            android:multiprocess="false" 
            android:name="rikka.shizuku.ShizukuProvider"/>
    </application>

</manifest>
